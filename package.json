{
	"name": "youtube-transcript",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"prebuild": "[ -f ./yt-dlp ] || (curl -L https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp -o ./yt-dlp && chmod +x ./yt-dlp)",
